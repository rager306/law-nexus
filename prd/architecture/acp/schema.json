{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://law-nexus.local/schemas/acp-record.schema.json",
  "title": "Minimal Architecture Control Plane Record Schema",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ArchitecturePromptRecord" },
    { "$ref": "#/$defs/ArchitectureProposal" },
    { "$ref": "#/$defs/DecisionCandidate" },
    { "$ref": "#/$defs/ProofGate" },
    { "$ref": "#/$defs/ArchitectureHealthFinding" }
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "Identifier": {
      "type": "string",
      "pattern": "^(APR|AP|DC|PG|AHF)-[0-9]{4}$"
    },
    "RepoRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(/|$)" },
          { "pattern": "^\\.gsd/e[x]ec(/|$)" }
        ]
      }
    },
    "SourceRef": {
      "type": "object",
      "required": ["path", "role"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/RepoRelativePath" },
        "role": { "$ref": "#/$defs/NonEmptyString" },
        "note": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "Safety": {
      "type": "object",
      "required": [
        "contains_secrets",
        "contains_provider_payloads",
        "contains_raw_vectors",
        "contains_unnecessary_raw_legal_text",
        "contains_local_absolute_paths",
        "claims_product_readiness",
        "claims_parser_completeness",
        "claims_falkordb_ingestion",
        "claims_legal_correctness",
        "claims_r035_validated",
        "claims_r037_validated",
        "claims_r038_validated"
      ],
      "additionalProperties": false,
      "properties": {
        "contains_secrets": { "const": false },
        "contains_provider_payloads": { "const": false },
        "contains_raw_vectors": { "const": false },
        "contains_unnecessary_raw_legal_text": { "const": false },
        "contains_local_absolute_paths": { "const": false },
        "claims_product_readiness": { "const": false },
        "claims_parser_completeness": { "const": false },
        "claims_falkordb_ingestion": { "const": false },
        "claims_legal_correctness": { "const": false },
        "claims_r035_validated": { "const": false },
        "claims_r037_validated": { "const": false },
        "claims_r038_validated": { "const": false }
      }
    },
    "BaseRecord": {
      "type": "object",
      "required": ["id", "record_kind", "title", "status", "source_refs", "safety"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "record_kind": { "$ref": "#/$defs/NonEmptyString" },
        "title": { "$ref": "#/$defs/NonEmptyString" },
        "status": { "$ref": "#/$defs/NonEmptyString" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SourceRef" }
        },
        "safety": { "$ref": "#/$defs/Safety" }
      }
    },
    "ArchitecturePromptRecord": {
      "allOf": [
        { "$ref": "#/$defs/BaseRecord" },
        {
          "type": "object",
          "required": ["record_kind", "capture_mode", "redaction_status", "user_intent", "response_snapshot", "outcome", "produced_proposal"],
          "properties": {
            "record_kind": { "const": "architecture_prompt_record" },
            "capture_mode": { "enum": ["verbatim", "redacted-verbatim", "summarized-with-quotes", "metadata-only"] },
            "redaction_status": { "enum": ["checked", "redacted", "not-required"] },
            "user_intent": { "$ref": "#/$defs/NonEmptyString" },
            "response_snapshot": { "$ref": "#/$defs/NonEmptyString" },
            "outcome": { "$ref": "#/$defs/NonEmptyString" },
            "produced_proposal": { "pattern": "^AP-[0-9]{4}$" }
          }
        }
      ]
    },
    "ArchitectureProposal": {
      "allOf": [
        { "$ref": "#/$defs/BaseRecord" },
        {
          "type": "object",
          "required": ["record_kind", "origin_prompt_record", "scope", "non_goals", "validation_plan", "decision_candidates"],
          "properties": {
            "record_kind": { "const": "architecture_proposal" },
            "origin_prompt_record": { "pattern": "^APR-[0-9]{4}$" },
            "scope": { "$ref": "#/$defs/NonEmptyString" },
            "non_goals": { "type": "array", "items": { "$ref": "#/$defs/NonEmptyString" } },
            "validation_plan": { "$ref": "#/$defs/NonEmptyString" },
            "decision_candidates": { "type": "array", "minItems": 1, "items": { "pattern": "^DC-[0-9]{4}$" } }
          }
        }
      ]
    },
    "DecisionCandidate": {
      "allOf": [
        { "$ref": "#/$defs/BaseRecord" },
        {
          "type": "object",
          "required": ["record_kind", "origin_proposal", "significance", "alternatives", "requires_proof_gate", "authority_required"],
          "properties": {
            "record_kind": { "const": "decision_candidate" },
            "origin_proposal": { "pattern": "^AP-[0-9]{4}$" },
            "significance": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/NonEmptyString" } },
            "alternatives": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/NonEmptyString" } },
            "requires_proof_gate": { "pattern": "^PG-[0-9]{4}$" },
            "authority_required": { "const": true }
          }
        }
      ]
    },
    "ProofGate": {
      "allOf": [
        { "$ref": "#/$defs/BaseRecord" },
        {
          "type": "object",
          "required": ["record_kind", "claim", "required_evidence_class", "blocks", "failure_mode"],
          "properties": {
            "record_kind": { "const": "proof_gate" },
            "claim": { "$ref": "#/$defs/NonEmptyString" },
            "required_evidence_class": { "$ref": "#/$defs/NonEmptyString" },
            "blocks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/NonEmptyString" } },
            "failure_mode": { "$ref": "#/$defs/NonEmptyString" }
          }
        }
      ]
    },
    "ArchitectureHealthFinding": {
      "allOf": [
        { "$ref": "#/$defs/BaseRecord" },
        {
          "type": "object",
          "required": ["record_kind", "severity", "category", "finding", "affected_records", "blocked_actions", "recommended_fix"],
          "properties": {
            "record_kind": { "const": "architecture_health_finding" },
            "severity": { "enum": ["info", "warning", "blocking"] },
            "category": { "$ref": "#/$defs/NonEmptyString" },
            "finding": { "$ref": "#/$defs/NonEmptyString" },
            "affected_records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/Identifier" } },
            "blocked_actions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/NonEmptyString" } },
            "recommended_fix": { "$ref": "#/$defs/NonEmptyString" }
          }
        }
      ]
    }
  }
}
